{
  "name": "YS-Servece-Code",
  "short_name": "YS-Servece-Code",
  "description": "Professional cloud development environment - VS Code in the browser",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#0B1220",
  "theme_color": "#3B82F6",
  "dir": "ltr",
  "lang": "en-US",
  "categories": ["development", "productivity"],
  "screenshots": [
    {
      "src": "/src/browser/media/pwa-icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/src/browser/media/pwa-icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "icons": [
    {
      "src": "/src/browser/media/pwa-icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/src/browser/media/pwa-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/src/browser/media/pwa-icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/src/browser/media/pwa-icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Open IDE",
      "short_name": "IDE",
      "description": "Open the YS-Servece-Code IDE",
      "url": "/"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": [
            "text/*",
            "application/json",
            "application/javascript",
            "application/typescript"
          ]
        }
      ]
    }
  }
}