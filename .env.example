# YS-Servece-Code — Environment Variables Reference
# ====================================================
# Copy this file to .env for local development.
# On Railway: set variables in the Variables tab.
# NEVER commit a .env file with real secrets.
#
# Source: every variable below maps directly to a
# process.env reference found in the source code.
# No invented variables.

# =============================================================================
# REQUIRED IN PRODUCTION
# =============================================================================

# Port the HTTP server listens on.
# Railway injects this automatically. Default in code: 8080. start.sh fallback: 5000.
# Source: src/node/cli.ts:819-820, start.sh
PORT=8080

# Plain-text authentication password.
# Read at startup then DELETED from process.env (not passed to child processes).
# Required when AUTH=password. Ignored when AUTH=none.
# Source: src/node/cli.ts:611-613, 657
PASSWORD=

# Argon2-hashed password (takes precedence over PASSWORD).
# Generate: echo -n "yourpassword" | argon2 randomsalt -e
# Read at startup then DELETED from process.env.
# Source: src/node/cli.ts:628-630, 658
HASHED_PASSWORD=

# =============================================================================
# START.SH VARIABLES (read by start.sh, not by TypeScript source directly)
# =============================================================================

# Authentication mode passed to code-server via --auth.
# Values: none | password
# Use "none" for local/Replit dev, "password" for production.
# Source: start.sh
AUTH=none

# Workspace directory that VS Code opens on startup.
# Source: start.sh
WORKSPACE_DIR=/home/runner/workspace

# =============================================================================
# SERVER NETWORKING
# =============================================================================

# Override the bind host. start.sh always passes 0.0.0.0 via --bind-addr,
# making this variable only useful when running the TypeScript binary directly.
# Source: src/node/cli.ts:812-813
CODE_SERVER_HOST=0.0.0.0

# Path to the YAML config file.
# Created automatically with a random password if it does not exist.
# Source: src/node/cli.ts:725
# CODE_SERVER_CONFIG=~/.config/code-server/config.yaml

# =============================================================================
# APPLICATION IDENTITY
# =============================================================================

# Replaces the {{app}} placeholder in VS Code title bar and welcome strings.
# Source: src/node/cli.ts:680
CODE_SERVER_APP_NAME=YS-Servece-Code

# Suffix appended to the session cookie name.
# Cookie becomes: code-server-session-<suffix>
# Useful when running multiple instances on the same domain.
# Source: src/node/cli.ts:634-635
# CODE_SERVER_COOKIE_SUFFIX=

# =============================================================================
# LOGGING
# =============================================================================

# Log verbosity. Values: trace | debug | info | warn | error
# Overridden by --log or --verbose CLI flags.
# Source: src/node/cli.ts:561-569
LOG_LEVEL=info

# Node environment. When "development", enables i18next debug logging.
# No other effect in this codebase.
# Source: src/node/i18n/index.ts:55
NODE_ENV=production

# =============================================================================
# TIMEOUTS & CONNECTION
# =============================================================================

# Milliseconds the server waits before closing after a client disconnects.
# Allows reconnection without session loss. Default: 10800000 (3 hours).
# Source: src/node/cli.ts:642-643
# CODE_SERVER_RECONNECTION_GRACE_TIME=10800000

# Seconds of inactivity before the server exits automatically.
# Must be an integer greater than 60. Unset = no idle shutdown.
# Source: src/node/cli.ts:646-653
# CODE_SERVER_IDLE_TIMEOUT_SECONDS=3600

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Disable file download capability in the VS Code UI. Values: 1 | true
# Source: src/node/cli.ts:616
# CS_DISABLE_FILE_DOWNLOADS=

# Disable the custom Getting Started page override. Values: 1 | true
# Source: src/node/cli.ts:620
# CS_DISABLE_GETTING_STARTED_OVERRIDE=

# Disable built-in path/domain port proxy routes. Values: 1 | true
# Source: src/node/cli.ts:624
# CS_DISABLE_PROXY=

# =============================================================================
# EXTENSIONS & MARKETPLACE
# =============================================================================

# JSON string overriding the VS Code extension gallery endpoint.
# Example: Open VSX registry (open-source alternative to VS Code Marketplace).
# Source: src/node/main.ts:207-209
# EXTENSIONS_GALLERY={"serviceUrl":"https://open-vsx.org/vscode/gallery","itemUrl":"https://open-vsx.org/vscode/item","resourceUrlTemplate":"https://open-vsx.org/vscode/unpkg/{publisher}/{name}/{version}/{path}"}

# GitHub OAuth token — enables Copilot and marketplace features.
# DELETED from process.env immediately after being read (not passed to children).
# Source: src/node/cli.ts:638-639, 659
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# PROXY / OUTBOUND
# =============================================================================

# Outbound HTTP/HTTPS proxy for extension downloads and update checks.
# All four variants are checked; HTTPS_PROXY takes precedence.
# Source: src/node/constants.ts:28
# HTTPS_PROXY=
# HTTP_PROXY=
# https_proxy=
# http_proxy=

# URI template for the port proxy shown in VS Code's PORTS tab.
# Normally auto-derived from --proxy-domain. Override only for custom setups.
# Format: //{{port}}.yourdomain.com
# Source: src/node/cli.ts:675-676, main.ts:198-199
# VSCODE_PROXY_URI=

# =============================================================================
# FILESYSTEM PATHS
# =============================================================================

# XDG base directory for user data.
# Affects: start.sh bundle location, and internal code-server data paths
# via the env-paths npm package (user-data-dir, extensions-dir, etc.)
# Source: start.sh, indirectly env-paths package
# XDG_DATA_HOME=

# =============================================================================
# RAILWAY-SPECIFIC (not read by application code — Railway platform settings)
# =============================================================================

# Tell Nixpacks which Node version to use. Must be 22 (required by package.json engines).
# Set this in Railway Variables tab, not in .env.
# NIXPACKS_NODE_VERSION=22
