# YS-Servece-Code — Environment Variables
# Copy this file to .env and fill in the values.
# Do NOT commit your .env file to version control.

# =============================================================================
# REQUIRED
# =============================================================================

# Port the server listens on (Railway sets this automatically)
PORT=8080

# Authentication password (plain text). Takes precedence over config file.
# Either PASSWORD or HASHED_PASSWORD must be set for password auth.
PASSWORD=

# Hashed password (argon2). Generated with: code-server --print-env hashed-password
# Takes precedence over PASSWORD.
HASHED_PASSWORD=

# =============================================================================
# OPTIONAL — Server / Networking
# =============================================================================

# Override the bind host (default: 0.0.0.0)
CODE_SERVER_HOST=0.0.0.0

# Override the config file path (default: ~/.config/code-server/config.yaml)
# CODE_SERVER_CONFIG=

# Custom app name displayed in the title bar and welcome message
CODE_SERVER_APP_NAME=YS-Servece-Code

# Suffix appended to the session cookie name (useful for multi-instance setups)
# CODE_SERVER_COOKIE_SUFFIX=

# Session socket path (auto-set internally; override only if needed)
# CODE_SERVER_SESSION_SOCKET=

# =============================================================================
# OPTIONAL — Proxy / Domain
# =============================================================================

# URI template for port proxying (e.g. //{{port}}-myhost.example.com)
# VSCODE_PROXY_URI=

# HTTP/HTTPS proxy for outbound requests
# HTTP_PROXY=
# HTTPS_PROXY=

# =============================================================================
# OPTIONAL — Timeouts
# =============================================================================

# Grace period (ms) before disconnecting an idle client (default: 10800000 = 3h)
# CODE_SERVER_RECONNECTION_GRACE_TIME=

# Idle timeout in seconds before the server exits (min: 60)
# CODE_SERVER_IDLE_TIMEOUT_SECONDS=

# =============================================================================
# OPTIONAL — Feature flags
# =============================================================================

# Disable file downloads from the editor (1 or true)
# CS_DISABLE_FILE_DOWNLOADS=

# Disable the Coder "Getting Started" override (1 or true)
# CS_DISABLE_GETTING_STARTED_OVERRIDE=

# Disable built-in path/domain proxy (1 or true)
# CS_DISABLE_PROXY=

# =============================================================================
# OPTIONAL — GitHub / Extensions
# =============================================================================

# GitHub OAuth token for extension marketplace authentication
# GITHUB_TOKEN=

# =============================================================================
# OPTIONAL — Logging
# =============================================================================

# Log level: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Node environment (development enables extra debug output)
# NODE_ENV=production
